# ==============================================================================
# PayLock Environment Configuration (Example)
# Copy this file to .env and adjust the values for your environment.
# ==============================================================================

# ------------------------------------------------------------------------------
# Server Settings
# ------------------------------------------------------------------------------

# HTTP server listening port (Default: 8080)
PAYLOCK_PORT=8080

# Maximum allowed upload file size in MB (Default: 500)
PAYLOCK_MAX_FILE_SIZE_MB=500

# Directory for local temporary data and file storage (Default: /tmp/data)
PAYLOCK_DATA_DIR=/tmp/data

# ------------------------------------------------------------------------------
# Walrus Decentralized Storage (v2 Infrastructure)
# ------------------------------------------------------------------------------

# Walrus Publisher endpoint for uploading blobs
# Default: https://publisher.walrus-testnet.walrus.space
PAYLOCK_WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space

# Walrus Aggregator endpoint for retrieving/streaming blobs
# Default: https://aggregator.walrus-testnet.walrus.space
PAYLOCK_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# Number of storage epochs to pay for when uploading blobs to Walrus.
# One epoch = 1 day on testnet, 2 weeks on mainnet. (Default: 5)
PAYLOCK_WALRUS_EPOCHS=5

# ------------------------------------------------------------------------------
# Sui Blockchain Configuration
# ------------------------------------------------------------------------------

# Sui JSON-RPC endpoint (e.g., devnet, testnet, or mainnet)
# Default: https://fullnode.testnet.sui.io:443
PAYLOCK_SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# The Object ID of the deployed Paywall Move package on Sui
PAYLOCK_PAYWALL_PACKAGE_ID=0x1900b6af964100c5baa91f5ce1b1435c6c88cda4b1ca6c76a1ec8c36949ad6cf

# ------------------------------------------------------------------------------
# Video Processing (FFmpeg)
# ------------------------------------------------------------------------------

# Path to ffmpeg binary (Ensure it's in your system PATH or provide full path)
PAYLOCK_FFMPEG_PATH=ffmpeg

# Path to ffprobe binary
PAYLOCK_FFPROBE_PATH=ffprobe

# Duration in seconds for the free preview clip generated for paid videos (Default: 10)
PAYLOCK_PREVIEW_DURATION=10
